<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/alertRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true"
    tools:ignore="Overdraw">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="40dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_alert_icon">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/alert_icon_description"
                    android:src="@drawable/ic_warning" />
            </FrameLayout>

            <TextView
                android:id="@+id/alertTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:text="@string/alert_title"
                android:textAppearance="@style/Text.SupSecu.Display"
                android:textColor="@color/danger" />

            <TextView
                android:id="@+id/alertIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="@color/ink"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/observed_address_label"
                android:textAppearance="@style/Text.SupSecu.Label" />

            <TextView
                android:id="@+id/alertObservedHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_domain_chip"
                android:fontFamily="monospace"
                android:textColor="@color/danger"
                android:textIsSelectable="true"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/alertOfficialLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textAppearance="@style/Text.SupSecu.Label" />

            <TextView
                android:id="@+id/alertOfficialUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_domain_chip"
                android:fontFamily="monospace"
                android:textColor="@color/success"
                android:textIsSelectable="true"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/alert_reason"
                android:textAppearance="@style/Text.SupSecu.Body" />

            <Button
                android:id="@+id/leaveSiteButton"
                style="@style/Widget.SupSecu.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/leave_site" />

            <Button
                android:id="@+id/openOfficialButton"
                style="@style/Widget.SupSecu.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/continueButton"
                style="@style/Widget.SupSecu.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/continue_risk" />
        </LinearLayout>
</ScrollView>
